---
import { people } from '../data/event.js';

const [bride, groom] = people;
---
<section class="split-lineage section-pad-soft" aria-labelledby="lineage-title">
  <div class="split-lineage-shell">
    <header class="split-lineage-heading" data-reveal>
      <p class="eyebrow">Family lineage</p>
      <h2 id="lineage-title" class="section-title compact">Rooted in blessing</h2>
      <p>
        Two homes, two histories and generations of faith, gathered into one joyful promise.
      </p>
    </header>

    <div class="ancestry-spread" aria-label="Bride and groom family lineage">
      <article class="ancestry-side bride" data-reveal>
        <span class="side-number" aria-hidden="true">01</span>
        <p class="side-kicker">Bride's Lineage</p>
        <h3>{bride.name}</h3>
        <p class="ancestry-parent">{bride.parentLine}</p>
        <p class="ancestry-copy">{bride.copy}</p>

        <div class="lineage-list" aria-label={`Family lineage for ${bride.name}`}>
          <p class="lineage-label">{bride.lineageTitle}</p>
          {bride.lineage.map((item) => (
            <div class="lineage-row">
              <strong>{item.names}</strong>
              <span>{item.house}</span>
            </div>
          ))}
        </div>
      </article>

      <div class="ancestry-divider" aria-hidden="true" data-reveal data-reveal-delay="120">
        <span class="lineage-node is-filled"></span>
        <i></i>
        <span class="union-mark">&amp;</span>
        <i></i>
        <span class="lineage-node"></span>
      </div>

      <article class="ancestry-side groom" data-reveal data-reveal-delay="160">
        <span class="side-number" aria-hidden="true">02</span>
        <p class="side-kicker">Groom's Lineage</p>
        <h3>{groom.name}</h3>
        <p class="ancestry-parent">{groom.parentLine}</p>
        <p class="ancestry-copy">{groom.copy}</p>

        <div class="lineage-list" aria-label={`Family lineage for ${groom.name}`}>
          <p class="lineage-label">{groom.lineageTitle}</p>
          {groom.lineage.map((item) => (
            <div class="lineage-row">
              <strong>{item.names}</strong>
              <span>{item.house}</span>
            </div>
          ))}
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .split-lineage {
    overflow: hidden;
    border-block: 1px solid var(--line-soft);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.46), rgba(246, 239, 227, 0.78)),
      var(--paper-soft);
  }

  .split-lineage-shell {
    width: min(100%, 1180px);
    margin-inline: auto;
  }

  .split-lineage-heading {
    max-width: 720px;
    margin: 0 auto clamp(3.2rem, 7vw, 6rem);
    text-align: center;
  }

  .split-lineage-heading p:last-child {
    max-width: 590px;
    margin: 1.05rem auto 0;
    color: var(--text);
    font-family: var(--display);
    font-size: clamp(1.28rem, 2.65vw, 1.88rem);
    font-weight: 300;
    line-height: 1.42;
  }

  .ancestry-spread {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 84px minmax(0, 1fr);
    gap: clamp(1.6rem, 4.8vw, 4.8rem);
    align-items: stretch;
    padding-block: clamp(0.6rem, 2vw, 1.5rem);
  }

  .ancestry-spread::before,
  .ancestry-spread::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: min(72%, 760px);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(198, 161, 91, 0.34), transparent);
  }

  .ancestry-spread::before { top: 0; }
  .ancestry-spread::after { bottom: 0; }

  .ancestry-side {
    position: relative;
    min-height: 500px;
    display: flex;
    flex-direction: column;
    padding-block: clamp(1.8rem, 4vw, 3.5rem);
  }

  .ancestry-side.bride {
    align-items: flex-end;
    text-align: right;
    padding-right: clamp(0.4rem, 1.5vw, 1.2rem);
  }

  .ancestry-side.groom {
    align-items: flex-start;
    text-align: left;
    padding-left: clamp(0.4rem, 1.5vw, 1.2rem);
  }

  .side-number {
    position: absolute;
    top: clamp(0.6rem, 2vw, 1.4rem);
    z-index: 0;
    color: rgba(198, 161, 91, 0.18);
    font-family: var(--display);
    font-size: clamp(5.5rem, 12vw, 10.5rem);
    font-weight: 300;
    line-height: 0.8;
    letter-spacing: -0.08em;
    pointer-events: none;
  }

  .bride .side-number { right: 0; }
  .groom .side-number { left: 0; }

  .side-kicker {
    position: relative;
    z-index: 1;
    margin: 0 0 1rem;
    color: var(--gold-antique);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .ancestry-side h3 {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--ink);
    font-family: var(--display);
    font-size: clamp(4.3rem, 9.6vw, 8.6rem);
    font-weight: 300;
    line-height: 0.82;
    letter-spacing: -0.04em;
  }

  .ancestry-parent {
    position: relative;
    z-index: 1;
    margin: 1.25rem 0 0;
    color: var(--gold-antique);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    line-height: 1.55;
    text-transform: uppercase;
  }

  .ancestry-copy {
    position: relative;
    z-index: 1;
    max-width: 430px;
    margin: 1.15rem 0 0;
    color: var(--text);
    font-family: var(--display);
    font-size: clamp(1.23rem, 2.45vw, 1.75rem);
    font-weight: 300;
    line-height: 1.36;
  }

  .lineage-list {
    position: relative;
    z-index: 1;
    width: min(100%, 470px);
    margin-top: auto;
    padding-top: clamp(1.35rem, 3vw, 2.1rem);
  }

  .lineage-list::before {
    content: '';
    display: block;
    width: min(100%, 340px);
    height: 1px;
    margin-bottom: 1.25rem;
    background: linear-gradient(90deg, transparent, rgba(198, 161, 91, 0.52));
  }

  .groom .lineage-list::before {
    background: linear-gradient(90deg, rgba(198, 161, 91, 0.52), transparent);
  }

  .lineage-label {
    margin: 0 0 0.6rem;
    color: var(--muted);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .lineage-row {
    padding-block: 0.72rem;
    border-bottom: 1px solid rgba(107, 90, 71, 0.1);
  }

  .lineage-row:last-child { border-bottom: 0; }

  .lineage-row strong {
    display: block;
    color: var(--ink);
    font-size: clamp(0.95rem, 1.25vw, 1.08rem);
    font-weight: 600;
    line-height: 1.48;
  }

  .lineage-row span {
    display: block;
    margin-top: 0.24rem;
    color: var(--muted);
    font-family: var(--display);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    font-style: italic;
    line-height: 1.35;
  }

  .ancestry-divider {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: stretch;
    min-height: 520px;
    padding-block: clamp(1.6rem, 3.5vw, 3rem);
  }

  .ancestry-divider i {
    display: block;
    width: 1px;
    flex: 1;
    min-height: 86px;
    background: linear-gradient(180deg, rgba(198, 161, 91, 0.38), rgba(198, 161, 91, 0.08));
  }

  .lineage-node {
    width: 17px;
    height: 17px;
    border-radius: 999px;
    border: 2px solid rgba(198, 161, 91, 0.7);
    background: var(--paper-soft);
    box-shadow: 0 0 0 10px rgba(198, 161, 91, 0.08);
  }

  .lineage-node.is-filled {
    background: var(--gold-antique);
    border-color: var(--gold-antique);
  }

  .union-mark {
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 999px;
    border: 1px solid rgba(198, 161, 91, 0.34);
    background: rgba(255, 253, 248, 0.78);
    color: var(--gold-antique);
    font-family: var(--display);
    font-size: 2.2rem;
    font-style: italic;
    line-height: 1;
    box-shadow: 0 14px 36px rgba(42, 28, 19, 0.04);
  }

  @media (max-width: 980px) {
    .split-lineage-heading {
      text-align: left;
      margin-inline: 0;
    }

    .split-lineage-heading p:last-child { margin-inline: 0; }

    .ancestry-spread {
      grid-template-columns: 1fr;
      gap: 0;
      padding-block: 0;
    }

    .ancestry-spread::before,
    .ancestry-spread::after { width: 100%; }

    .ancestry-side,
    .ancestry-side.bride,
    .ancestry-side.groom {
      min-height: auto;
      align-items: flex-start;
      text-align: left;
      padding: 2.6rem 0;
    }

    .bride .side-number,
    .groom .side-number {
      left: auto;
      right: 0;
    }

    .ancestry-divider {
      min-height: auto;
      height: 72px;
      padding: 0;
      flex-direction: row;
      justify-content: center;
    }

    .ancestry-divider i {
      width: min(28vw, 140px);
      height: 1px;
      min-height: 1px;
      flex: 0 0 auto;
      background: linear-gradient(90deg, rgba(198, 161, 91, 0.08), rgba(198, 161, 91, 0.42));
    }

    .ancestry-divider i:last-of-type {
      background: linear-gradient(90deg, rgba(198, 161, 91, 0.42), rgba(198, 161, 91, 0.08));
    }

    .lineage-node { display: none; }

    .lineage-list { margin-top: 2rem; }

    .lineage-list::before,
    .groom .lineage-list::before {
      width: 100%;
      background: linear-gradient(90deg, rgba(198, 161, 91, 0.52), transparent);
    }
  }

  @media (max-width: 640px) {
    .split-lineage-heading { margin-bottom: 2.8rem; }

    .ancestry-side h3 { font-size: clamp(4.2rem, 22vw, 6.8rem); }

    .side-number {
      font-size: 6.6rem;
      opacity: 0.7;
    }

    .ancestry-copy { font-size: 1.32rem; }

    .union-mark {
      width: 48px;
      height: 48px;
      font-size: 2rem;
    }
  }
</style>
