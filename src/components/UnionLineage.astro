---
import { people } from '../data/event.js';

const [bride, groom] = people;
const lineageEntries = [
  {
    index: '01',
    side: 'bride',
    person: bride,
    intro: 'A daughter carrying the warmth, prayers and heritage of her family into this promise.'
  },
  {
    index: '02',
    side: 'groom',
    person: groom,
    intro: 'A son shaped by faith, family values and the generations who walked before him.'
  }
];
---

<section id="story" class="union-lineage section-pad" aria-labelledby="union-title">
  <div class="union-shell">
    <header class="union-heading" data-reveal>
      <p class="eyebrow">The grace of union</p>
      <h2 id="union-title" class="section-title compact">Two families, one promise</h2>
      <p>
        With gratitude for the homes, prayers and generations that shaped Cera and Tony, this promise is held by both families with joy.
      </p>
    </header>

    <div class="union-spread" aria-label="Family lineage of Cera and Tony">
      {lineageEntries.map((entry, index) => (
        <article
          class:list={['union-person', `union-person-${entry.side}`]}
          data-reveal
          data-reveal-delay={index === 1 ? '140' : '0'}
        >
          <span class="union-index" aria-hidden="true">{entry.index}</span>
          <p class="union-role">{entry.person.role}</p>
          <h3>{entry.person.name}</h3>
          <p class="union-parent">{entry.person.parentLine}</p>
          <p class="union-copy">{entry.intro}</p>

          <div class="union-lineage-block">
            <p class="lineage-label">{entry.person.lineageTitle}</p>
            <div class="lineage-list">
              {entry.person.lineage.map((item, itemIndex) => (
                <div class="lineage-row">
                  <strong>{item.names}</strong>
                  <small>{item.house}</small>
                  {itemIndex === 0 && <span class="lineage-and" aria-hidden="true">&amp;</span>}
                </div>
              ))}
            </div>
          </div>
        </article>
      ))}

      <div class="union-divider" aria-hidden="true">
        <span class="divider-node divider-node-top"></span>
        <span class="divider-mark">&amp;</span>
        <span class="divider-node divider-node-bottom"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .union-lineage {
    overflow: clip;
    border-block: 1px solid var(--line-soft);
    background:
      radial-gradient(circle at 50% 18%, rgba(231, 211, 161, 0.16), transparent 24rem),
      linear-gradient(180deg, rgba(255, 253, 248, 0.54), rgba(246, 239, 227, 0.58));
  }

  .union-shell {
    width: min(100%, 1180px);
    margin-inline: auto;
  }

  .union-heading {
    width: min(100%, 760px);
    margin: 0 auto clamp(3.6rem, 7vw, 6.4rem);
    text-align: center;
  }

  .union-heading .section-title {
    margin-top: 0.85rem;
  }

  .union-heading p:last-child {
    max-width: 680px;
    margin: 1.15rem auto 0;
    color: var(--text);
    font-family: var(--display);
    font-size: clamp(1.24rem, 2.4vw, 1.72rem);
    font-weight: 300;
    line-height: 1.42;
  }

  .union-spread {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(72px, 0.16fr) minmax(0, 1fr);
    gap: clamp(1.4rem, 4.5vw, 4.6rem);
    align-items: stretch;
  }

  .union-person {
    position: relative;
    min-height: 640px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(1rem, 3vw, 2.4rem);
  }

  .union-person-bride {
    text-align: right;
    align-items: flex-end;
  }

  .union-person-groom {
    grid-column: 3;
    text-align: left;
    align-items: flex-start;
    padding-top: clamp(4rem, 8vw, 7rem);
  }

  .union-index {
    position: absolute;
    top: clamp(0.2rem, 1.8vw, 1.4rem);
    color: rgba(167, 122, 53, 0.15);
    font-family: var(--display);
    font-size: clamp(7rem, 16vw, 13rem);
    font-weight: 300;
    line-height: 0.8;
    letter-spacing: -0.08em;
    pointer-events: none;
    user-select: none;
  }

  .union-person-bride .union-index {
    right: -0.04em;
  }

  .union-person-groom .union-index {
    left: -0.08em;
  }

  .union-role,
  .lineage-label {
    margin: 0;
    color: var(--gold-antique);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .union-person h3 {
    position: relative;
    margin: 0.35rem 0 0;
    color: var(--ink);
    font-family: var(--display);
    font-size: clamp(4.6rem, 11vw, 9.4rem);
    font-weight: 300;
    letter-spacing: -0.065em;
    line-height: 0.86;
    z-index: 1;
  }

  .union-parent {
    margin: 1.15rem 0 0;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .union-copy {
    max-width: 420px;
    margin: 1.15rem 0 0;
    color: var(--text);
    font-family: var(--display);
    font-size: clamp(1.22rem, 2.4vw, 1.64rem);
    font-weight: 300;
    line-height: 1.36;
  }

  .union-lineage-block {
    width: min(100%, 460px);
    margin-top: clamp(2.3rem, 5vw, 4.2rem);
    padding-top: 1.35rem;
    border-top: 1px solid rgba(198, 161, 91, 0.22);
  }

  .lineage-list {
    display: grid;
    gap: 1.05rem;
    margin-top: 1.05rem;
  }

  .lineage-row {
    position: relative;
    display: grid;
    gap: 0.28rem;
  }

  .lineage-row strong {
    color: var(--ink);
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.52;
  }

  .lineage-row small {
    color: var(--muted);
    font-family: var(--display);
    font-size: 1.08rem;
    font-style: italic;
    line-height: 1.22;
  }

  .lineage-and {
    display: inline-grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    margin-top: 0.72rem;
    color: var(--gold-antique);
    font-family: var(--display);
    font-size: 1.05rem;
    font-style: italic;
    border: 1px solid rgba(198, 161, 91, 0.26);
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.58);
  }

  .union-person-bride .lineage-and {
    margin-left: auto;
  }

  .union-divider {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    transform: translateX(-50%);
    background: linear-gradient(transparent, rgba(198, 161, 91, 0.32) 9%, rgba(198, 161, 91, 0.32) 91%, transparent);
  }

  .union-divider::before {
    content: '';
    position: absolute;
    inset: 0;
    transform: scaleY(0);
    transform-origin: top;
    background: linear-gradient(transparent, var(--gold) 14%, rgba(198, 161, 91, 0.24) 88%, transparent);
    transition: transform 1200ms 140ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .union-spread:has(.is-visible) .union-divider::before {
    transform: scaleY(1);
  }

  .divider-node,
  .divider-mark {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 999px;
  }

  .divider-node {
    width: 14px;
    height: 14px;
    border: 1px solid var(--gold-antique);
    background: var(--paper);
    box-shadow: 0 0 0 8px rgba(198, 161, 91, 0.09);
  }

  .divider-node-top { top: clamp(4rem, 8vw, 6rem); }
  .divider-node-bottom { bottom: clamp(4rem, 8vw, 6rem); }

  .divider-mark {
    top: 50%;
    display: grid;
    place-items: center;
    width: 4.35rem;
    height: 4.35rem;
    color: var(--gold-antique);
    font-family: var(--display);
    font-size: 2.4rem;
    font-style: italic;
    background: color-mix(in srgb, var(--paper) 86%, white);
    border: 1px solid rgba(198, 161, 91, 0.28);
    box-shadow: 0 18px 42px rgba(42, 28, 19, 0.06);
  }

  @media (max-width: 980px) {
    .union-spread {
      grid-template-columns: 1fr;
      gap: 3.4rem;
    }

    .union-person,
    .union-person-bride,
    .union-person-groom {
      grid-column: auto;
      min-height: auto;
      align-items: center;
      text-align: center;
      padding-block: 0;
    }

    .union-person-groom {
      padding-top: 0;
    }

    .union-person h3 {
      font-size: clamp(4.3rem, 17vw, 7.2rem);
    }

    .union-index {
      position: relative;
      inset: auto !important;
      order: -1;
      margin-bottom: -1.6rem;
      font-size: clamp(5.5rem, 24vw, 8rem);
    }

    .union-copy,
    .union-lineage-block {
      margin-inline: auto;
    }

    .union-divider {
      position: relative;
      left: auto;
      top: auto;
      bottom: auto;
      order: 2;
      width: min(100%, 420px);
      height: 1px;
      margin: -0.6rem auto;
      transform: none;
      background: linear-gradient(90deg, transparent, rgba(198, 161, 91, 0.32), transparent);
    }

    .union-divider::before,
    .divider-node {
      display: none;
    }

    .divider-mark {
      top: 50%;
      width: 3.35rem;
      height: 3.35rem;
      font-size: 1.85rem;
      transform: translate(-50%, -50%);
    }

    .lineage-and {
      margin-inline: auto !important;
    }
  }

  @media (max-width: 640px) {
    .union-heading {
      margin-bottom: 3rem;
    }

    .union-heading p:last-child {
      font-size: 1.2rem;
    }

    .union-role,
    .lineage-label {
      font-size: 0.58rem;
      letter-spacing: 0.2em;
    }

    .union-parent {
      font-size: 0.62rem;
      letter-spacing: 0.12em;
    }

    .union-lineage-block {
      padding-top: 1.05rem;
    }
  }
</style>
